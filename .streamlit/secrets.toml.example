# Reference only — copy these keys into your Streamlit Community Cloud app's
# "Settings -> Secrets" box (not this file; that dashboard is the real secrets
# store in the cloud). For local runs, copy this to .streamlit/secrets.toml
# instead (already gitignored) or just use a local .env — see .env.example.
#
# Streamlit exposes every top-level key here as an environment variable too,
# so app.py's os.environ.get(...) calls work unchanged in the cloud.

ANTHROPIC_API_KEY = ""
OPENAI_API_KEY = ""
GOOGLE_API_KEY = ""
DATABASE_URL = ""
