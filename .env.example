# Copy to .env and fill in whichever of these you need.
# Every value is optional — API keys can also be typed directly into the
# app's "Generate Questions" tab, and without DATABASE_URL the app falls
# back to local-file storage.

# Prefills the API key field in Materials -> Generate Questions when the
# matching provider is selected. Keys are only held in memory at runtime.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# If set, switches checkpoint/session-log persistence to Postgres instead
# of local JSON files. Required for durable state on most cloud hosts.
# See README.md's "Cloud Deployment & Session Persistence" section.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=
